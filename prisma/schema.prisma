generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Novel {
  id          String   @id @default(cuid())
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  volumes     Volume[]
}

model Volume {
  id          String   @id @default(cuid())
  novelId     String
  title       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  novel       Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  milestones  Milestone[]
  worldLayers WorldLayer[]
  worldNodes  WorldNode[]

  @@index([novelId])
}

model Milestone {
  id                      String           @id @default(cuid())
  volumeId                String
  title                   String
  summary                 String?
  maxChaptersPerMilestone Int?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  volume                  Volume           @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  scenes                  Scene[]
  sceneGraphEdges         SceneGraphEdge[]
  chapters                Chapter[]

  @@index([volumeId])
}

model Scene {
  id            String           @id @default(cuid())
  milestoneId   String
  outline       String
  explanation   String
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  milestone     Milestone        @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  outgoingEdges SceneGraphEdge[] @relation("SceneGraphEdgeFrom")
  incomingEdges SceneGraphEdge[] @relation("SceneGraphEdgeTo")
  chapterLinks  ChapterSceneLink[]
  worldLinks    SceneWorldLink[]

  @@index([milestoneId])
}

model SceneGraphEdge {
  id           String    @id @default(cuid())
  milestoneId  String
  fromSceneId  String
  toSceneId    String
  relationship String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  milestone    Milestone @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  fromScene    Scene     @relation("SceneGraphEdgeFrom", fields: [fromSceneId], references: [id], onDelete: Cascade)
  toScene      Scene     @relation("SceneGraphEdgeTo", fields: [toSceneId], references: [id], onDelete: Cascade)

  @@unique([fromSceneId, toSceneId])
  @@index([milestoneId])
  @@index([toSceneId])
}

model Chapter {
  id          String             @id @default(cuid())
  milestoneId String
  title       String
  body        String             @default("")
  wordCount   Int                @default(0)
  savedVersion Int               @default(0)
  maxWordCount Int               @default(3000)
  fontFamily  String             @default("Georgia")
  fontSize    Int                @default(16)
  lineHeight  Float              @default(1.7)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  milestone   Milestone          @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  sceneLinks  ChapterSceneLink[]

  @@index([milestoneId])
}

model ChapterSceneLink {
  id        String   @id @default(cuid())
  chapterId String
  sceneId   String
  sortOrder Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  scene     Scene    @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  @@unique([chapterId, sceneId])
  @@index([sceneId])
}

model WorldLayer {
  id              String   @id @default(cuid())
  volumeId        String
  layerKey        String
  displayName     String
  position        Int
  orderingMode    String
  vibe            String?
  constraints     String?
  narrativeFlavor String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  volume          Volume   @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  nodes           WorldNode[]

  @@unique([volumeId, layerKey])
  @@index([volumeId, position])
}

model WorldNode {
  id                    String     @id @default(cuid())
  volumeId              String
  layerId               String
  name                  String
  positionJustification String?
  advantages            String?
  disadvantages         String?
  relationships         String?
  geographicalLocation  String?
  traditions            String?
  specialTraits         String?
  lastReminderQueuedAt  DateTime?
  nextReminderDueAt     DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  volume                Volume     @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  layer                 WorldLayer @relation(fields: [layerId], references: [id], onDelete: Cascade)
  sceneLinks            SceneWorldLink[]

  @@index([volumeId, layerId])
  @@index([nextReminderDueAt])
}

model SceneWorldLink {
  id          String    @id @default(cuid())
  sceneId     String
  worldNodeId String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  scene       Scene     @relation(fields: [sceneId], references: [id], onDelete: Cascade)
  worldNode   WorldNode @relation(fields: [worldNodeId], references: [id], onDelete: Cascade)

  @@unique([sceneId, worldNodeId])
  @@index([worldNodeId])
}
